# 개발 서버에서는 /gateway 경로를 Vite proxy가 실제 Gateway로 전달합니다.
# CORS 설정이 Gateway에 반영되기 전에도 로컬 개발 환경에서 API 호출을 검증할 수 있습니다.
VITE_API_BASE_URL=/gateway
VITE_API_PROXY_TARGET=http://100.119.201.17:9000

# JWT accessToken은 Set-Cookie: token=<JWT> 형태의 HttpOnly 쿠키로 내려옵니다.
# axios 요청마다 브라우저 쿠키를 함께 보내려면 true로 둡니다.
VITE_API_WITH_CREDENTIALS=true
